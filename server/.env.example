# Copy this file to .env and fill in your real Cleanverse credentials.
# NEVER commit the real .env file. It is already in .gitignore.

PORT=8787

# Cleanverse sandbox environment
CLEANVERSE_ENV=sandbox
CLEANVERSE_BASE_URL=https://uatapi.cleanverse.com/api/cooperate

# Issued by Cleanverse for this hackathon - keep secret
CLEANVERSE_APP_ID=
CLEANVERSE_API_KEY=
